  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 854a0a46854405240bc255c269ba2b49, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Level1ProgressController
  levelQuest: {fileID: 11400000, guid: e2dfbd530fbe4ad418bf134b93f9c1f3, type: 2}
  canvasDialog: {fileID: 1963381033}
  bitCompanion: {fileID: 0}
  questUI: {fileID: 859336984}
  gameOver: {fileID: 835556284}
  levelPortal: {fileID: 1083149690}
  steps:
  - itemId: monitor
    displayName: Monitor
    worldObject: {fileID: 0}
    afterGrabDialog:
    - categoryName: Bit - Monitor Info
      panelSprite: {fileID: -991878179, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CBagus, itu monitor. Perangkat ini menampilkan informasi dari
        komputer. Tanpa monitor, kamu tidak bisa melihat apa yang sedang terjadi
        di sistem.\u201D "
    - categoryName: Bit - Monitor Info
      panelSprite: {fileID: -991878179, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: '"Ayo pasang Monitor ke Meja Putih yang ada di ujung sana"'
    afterPlaceDialog:
    - categoryName: Bit - Monitor Placed
      panelSprite: {fileID: -1532018518, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CMonitor berhasil terpasang. Perangkat ini berfungsi untuk menampilkan
        informasi, gambar, dan status sistem komputer.\u201D"
  - itemId: keyboard
    displayName: Keyboard
    worldObject: {fileID: 0}
    afterGrabDialog:
    - categoryName: Bit - Keyboard grabbed
      panelSprite: {fileID: -1532018518, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CItu keyboard, perangkat input untuk mengetik dan memberi perintah.
        Ambil dan pasang ke slot yang sesuai agar sistem bisa menerima instruksi
        lagi.\u201D"
    - categoryName: Bit - Keyboard grabbed
      panelSprite: {fileID: -1532018518, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: '"Ayo pasang Keyboard ke Meja Putih yang ada di ujung sana"'
    afterPlaceDialog:
    - categoryName: Bit - Keyboard placed
      panelSprite: {fileID: -1532018518, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CKeyboard berhasil terpasang. Perangkat ini berfungsi untuk
        memasukkan teks, angka, dan perintah ke dalam komputer.\u201D"
  - itemId: mouse
    displayName: MOUSE
    worldObject: {fileID: 0}
    afterGrabDialog:
    - categoryName: Bit - Mouse grabbed
      panelSprite: {fileID: -991878179, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CKamu menemukan mouse. Perangkat ini digunakan untuk mengarahkan
        pointer dan memilih perintah. Dengan ini, kontrol sistem akan lebih mudah
        dipulihkan.\u201D"
    - categoryName: Bit - Mouse grabbed
      panelSprite: {fileID: -991878179, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: '"Ayo pasang Mouse ke Meja Putih yang ada di ujung sana"'
    afterPlaceDialog:
    - categoryName: Bit - Mouse placed
      panelSprite: {fileID: -1532018518, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CMouse berhasil terpasang. Perangkat ini berfungsi untuk menggerakkan
        pointer, memilih menu, dan menjalankan perintah dengan lebih mudah.\u201D"
  - itemId: cpu
    displayName: CPU
    worldObject: {fileID: 0}
    afterGrabDialog:
    - categoryName: 'Bit - CPU Grabbed '
      panelSprite: {fileID: -991878179, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CItu CPU utama. Bagian ini menjadi pusat pemrosesan komputer.
        Kalau CPU tidak aktif, perangkat lain tidak akan bisa bekerja dengan benar.\u201D"
    afterPlaceDialog:
    - categoryName: Bit - CPU Placed
      panelSprite: {fileID: -1532018518, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CCPU berhasil terpasang. Perangkat ini berfungsi sebagai pusat
        pemrosesan yang menjalankan perintah dan mengolah data komputer.\u201D"
  - itemId: power_ups
    displayName: POWER SUPPLY
    worldObject: {fileID: 0}
    afterGrabDialog:
    - categoryName: Bit - Power Grabbed
      panelSprite: {fileID: -991878179, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CItu sumber power atau UPS. Semua perangkat membutuhkan daya
        untuk menyala. Aktifkan bagian ini agar sistem lab bisa mulai hidup kembali.\u201D"
    - categoryName: Bit - Power Grabbed
      panelSprite: {fileID: -991878179, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: '"Ayo pasang Power UPS ke Meja Putih yang ada di ujung sana"'
    afterPlaceDialog:
    - categoryName: Bit - Power placed
      panelSprite: {fileID: -1532018518, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
      content: "\u201CPower berhasil terpasang. Perangkat ini berfungsi untuk memberikan
        daya agar seluruh sistem komputer dapat menyala dan bekerja.\u201D"
  grabDialogDelay: 1.5
  hideWorldItemsBeforeQuest: 1
  finalDialog:
  - categoryName: Bit - Complete
    panelSprite: {fileID: -1532018518, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
    content: '"Semua perangkat dasar berhasil dipulihkan. Sistem kini mulai stabil."'
  - categoryName: Bit - Next Level
    panelSprite: {fileID: -991878179, guid: 6df5319dfd5ea034d9de2619c0c4dfff, type: 3}
    content: '"Portal menuju area berikutnya sudah terbuka. Ayo lanjutkan perjalanan
      kita."'
