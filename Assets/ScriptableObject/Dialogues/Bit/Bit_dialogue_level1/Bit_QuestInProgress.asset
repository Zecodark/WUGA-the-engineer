  m_Script: {fileID: 11500000, guid: 3f7dbea39123ea846ae2349578084e0c, type: 3}
  m_Name: Bit_QuestInProgress
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  speakerName: Bit
  lines:
  - Kamu sudah selesai dengan questnya?
  - Item tersebar di sekitar area. Periksa meja, rak, dan platform.
  - Aku Bit, robot pemandu yang membantumu memahami dunia ini.
  - Ini adalah dunia digital di dalam sistem komputer yang sedang rusak.
  choices:
  - choiceText: Dimana Itemnya?
    nextLineIndex: 1
    questToGive: {fileID: 0}
  - choiceText: Siapa Kamu?
    nextLineIndex: 2
    questToGive: {fileID: 0}
  - choiceText: Ceritakan tentang dunia ini
    nextLineIndex: 3
    questToGive: {fileID: 0}
  - choiceText: Tidak, lanjutkan pencarian.
    nextLineIndex: -1
    questToGive: {fileID: 0}
  questToGive: {fileID: 0}
